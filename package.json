{
  "name": "templify-production",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "preinstall": "node scripts/enforce-node.mjs",
    "predev": "node scripts/enforce-node.mjs",
    "prebuild": "node scripts/enforce-node.mjs",
    "prestart": "node scripts/enforce-node.mjs",
    "pretest": "node scripts/enforce-node.mjs",
    "dev": "next dev",
    "dev:worker": "tsx watch src/server/worker.ts",
    "build": "next build",
    "postinstall": "prisma generate && playwright install --with-deps chromium",
    "start": "next start",
    "test": "node -r dotenv/config --import tsx --test tests/**/*.test.ts",
    "worker": "playwright install-deps chromium && NODE_ENV=production tsx src/server/worker.ts",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "bullmq": "^5.12.12",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "handlebars": "^4.7.8",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.511.0",
    "nanoid": "^5.0.7",
    "next": "^15.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.16.3",
    "playwright": "^1.48.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sanitize-html": "^2.17.2",
    "stripe": "^21.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^7.6.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
