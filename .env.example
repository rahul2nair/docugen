# Redis Configuration
REDIS_URL=redis://localhost:6379

# Application Configuration
APP_URL=http://localhost:3000

# Supabase Configuration (for persistent user data)
NEXT_PUBLIC_SUPABASE_URL=
# Required for browser auth flows
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Preferred: Supabase secret key (sb_secret_...)
SUPABASE_SECRET_KEY=
# Legacy fallback: older Supabase service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Supabase Postgres
# Use the Supabase Postgres connection strings from Project Settings -> Database.
# DATABASE_URL is used by the Prisma runtime client.
DATABASE_URL=
# DIRECT_URL is optional, but recommended for Prisma CLI migrations on the direct 5432 connection.
DIRECT_URL=

# Used for encrypting sensitive values before persisting (API keys)
SECRETS_ENCRYPTION_KEY=replace-with-long-random-secret

# Stripe Billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Job Retention (in hours)
JOB_RETENTION_HOURS=24

# Worker and PDF renderer
WORKER_CONCURRENCY=1
PDF_RENDERER_ENDPOINT=
PDF_RENDERER_AUTH_TOKEN=
PDF_RENDERER_TIMEOUT_MS=45000
PDF_RENDERER_FALLBACK_TO_LOCAL=true

# Backblaze B2 Configuration
# Get these from your Backblaze B2 account:
# 1. Create an application key in the B2 console
# 2. Create a bucket for storing documents
B2_APPLICATION_KEY_ID=your_app_key_id_here
B2_APPLICATION_KEY=your_app_key_here
B2_BUCKET_ID=your_bucket_id_here
B2_BUCKET_NAME=your_bucket_name_here
